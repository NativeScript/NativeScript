<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0-windows10.0.26100.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <Platforms>x86;x64;ARM64</Platforms>
    <AssemblyName>NativeScript.Widgets</AssemblyName>
    <RootNamespace>NativeScript.Widgets</RootNamespace>
    <Nullable>enable</Nullable>
    <!--
      UseUwp projects Windows Runtime types (Windows.UI.Xaml.Controls.Panel,
      DependencyProperty, UIElement, etc.) via CsWinRT — the same mechanism the
      runtime template uses.  No Windows App SDK / WinUI 3 packages required.
    -->
    <UseUwp>true</UseUwp>
        <!-- This project does not emit CsWinRT AOT/native activators. We use a
          managed CCW/native-pointer pattern (`INativeIdentifiable`) for widgets
          instead of generating WinMD-native activation exports. -->
  </PropertyGroup>

  <!-- No additional targets. -->
</Project>
