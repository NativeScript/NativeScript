{
	"name": "@nativescript/vite",
	"version": "8.0.0-alpha.37",
	"description": "Vite for NativeScript",
	"main": "./index.js",
	"module": "./index.js",
	"types": "./index.d.ts",
	"type": "module",
	"files": ["**/*.d.ts", "**/*.js", "**/*.mjs", "**/*.cjs", "**/*.map"],
	"exports": {
		".": {
			"types": "./index.d.ts",
			"import": "./index.js",
			"default": "./index.js"
		},
		"./angular": {
			"types": "./configuration/angular.d.ts",
			"import": "./configuration/angular.js",
			"default": "./configuration/angular.js"
		},
		"./react": {
			"types": "./configuration/react.d.ts",
			"import": "./configuration/react.js",
			"default": "./configuration/react.js"
		},
		"./solid": {
			"types": "./configuration/solid.d.ts",
			"import": "./configuration/solid.js",
			"default": "./configuration/solid.js"
		},
		"./vue": {
			"types": "./configuration/vue.d.ts",
			"import": "./configuration/vue.js",
			"default": "./configuration/vue.js"
		},
		"./javascript": {
			"types": "./configuration/javascript.d.ts",
			"import": "./configuration/javascript.js",
			"default": "./configuration/javascript.js"
		},
		"./typescript": {
			"types": "./configuration/typescript.d.ts",
			"import": "./configuration/typescript.js",
			"default": "./configuration/typescript.js"
		},
		"./base": {
			"types": "./configuration/base.d.ts",
			"import": "./configuration/base.js",
			"default": "./configuration/base.js"
		},
		"./hmr/client/index.js": "./hmr/client/index.js",
		"./hmr/entry-runtime.js": "./hmr/entry-runtime.js",
		"./hmr/shared/runtime/vendor-bootstrap": "./hmr/shared/runtime/vendor-bootstrap.js",
		"./hmr/shared/runtime/vendor-bootstrap.js": "./hmr/shared/runtime/vendor-bootstrap.js",
		"./hmr/shared/runtime/root-placeholder": "./hmr/shared/runtime/root-placeholder.js",
		"./hmr/shared/runtime/root-placeholder.js": "./hmr/shared/runtime/root-placeholder.js",
		"./hmr/shared/runtime/boot-session": "./hmr/shared/runtime/boot-session.js",
		"./hmr/shared/runtime/boot-session.js": "./hmr/shared/runtime/boot-session.js",
		"./hmr/shared/runtime/dev-overlay": "./hmr/shared/runtime/dev-overlay.js",
		"./hmr/shared/runtime/dev-overlay.js": "./hmr/shared/runtime/dev-overlay.js",
		"./hmr/shared/runtime/browser-runtime-contract": "./hmr/shared/runtime/browser-runtime-contract.js",
		"./hmr/shared/runtime/browser-runtime-contract.js": "./hmr/shared/runtime/browser-runtime-contract.js",
		"./hmr/shared/runtime/session-bootstrap": "./hmr/shared/runtime/session-bootstrap.js",
		"./hmr/shared/runtime/session-bootstrap.js": "./hmr/shared/runtime/session-bootstrap.js",
		"./hmr/shared/runtime/http-only-boot": "./hmr/shared/runtime/http-only-boot.js",
		"./hmr/shared/runtime/http-only-boot.js": "./hmr/shared/runtime/http-only-boot.js",
		"./hmr/shared/runtime/module-provenance": "./hmr/shared/runtime/module-provenance.js",
		"./hmr/shared/runtime/module-provenance.js": "./hmr/shared/runtime/module-provenance.js",
		"./hmr/shared/runtime/hooks": "./hmr/shared/runtime/hooks.js",
		"./hmr/shared/runtime/hooks.js": "./hmr/shared/runtime/hooks.js",
		"./runtime/core-aliases-early": "./runtime/core-aliases-early.js",
		"./runtime/core-aliases-early.js": "./runtime/core-aliases-early.js"
	},
	"bin": {
		"nativescript-vite": "./bin/cli.cjs"
	},
	"keywords": [
		"nativescript",
		"vite"
	],
	"dependencies": {
		"@babel/core": "^7.28.0",
		"@babel/generator": "^7.28.0",
		"@babel/parser": "^7.28.0",
		"@babel/plugin-transform-typescript": "^7.28.0",
		"@rollup/plugin-alias": "^6.0.0",
		"@rollup/plugin-commonjs": "^29.0.0",
		"@rollup/plugin-replace": "^6.0.2",
		"css": "^3.0.0",
		"esbuild": "^0.27.4",
		"minimist": "^1.2.8",
		"sass": ">=1.70.0 <2",
		"vite": "^8.0.0",
		"vite-plugin-static-copy": "^4.0.1",
		"ws": "^8.18.0"
	},
	"peerDependencies": {
		"@analogjs/vite-plugin-angular": "^2.0.0",
		"@angular/build": "^21.0.0",
		"@vitejs/plugin-vue": "^6.0.5",
		"@vitejs/plugin-vue-jsx": "^5.1.5",
		"@vue/compiler-sfc": "^3.5.0",
		"react-reconciler": "^0.32.0",
		"vite-plugin-solid": "^2.11.11",
		"vue-tsc": "^3.2.0"
	},
	"peerDependenciesMeta": {
		"@analogjs/vite-plugin-angular": { "optional": true },
		"@angular/build": { "optional": true },
		"@vitejs/plugin-vue": { "optional": true },
		"@vitejs/plugin-vue-jsx": { "optional": true },
		"@vue/compiler-sfc": { "optional": true },
		"react-reconciler": { "optional": true },
		"vite-plugin-solid": { "optional": true },
		"vue-tsc": { "optional": true }
	},
	"devDependencies": {
		"@analogjs/vite-plugin-angular": "^2.0.0",
		"@angular/build": "^21.0.0",
		"@types/css": "^0.0.38",
		"@types/node": "^24.9.1",
		"@vitejs/plugin-vue": "^6.0.5",
		"@vitejs/plugin-vue-jsx": "^5.1.5",
		"@vue/compiler-sfc": "^3.5.0",
		"react-reconciler": "^0.32.0",
		"vite-plugin-solid": "^2.11.11",
		"vitest": "~4.0.9",
		"vue-tsc": "^3.2.0"
	},
	"homepage": "https://docs.nativescript.org/configuration/vite",
	"repository": {
		"type": "git",
		"url": "https://github.com/NativeScript/NativeScript"
	},
	"author": {
		"name": "NativeScript",
		"email": "oss@nativescript.org"
	}
}
